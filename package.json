{
	"name": "runestone",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"engines": {
		"node": ">=22.12.0 <23.0.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=22.12.0 <23.0.0",
			"onFail": "warn"
		},
		"packageManager": {
			"name": "npm",
			"version": ">=11.5.1 <12.0.0",
			"onFail": "warn"
		}
	},
	"packageManager": "npm@11.5.1",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "vite preview",
		"routes:generate": "tsr generate",
		"routes:watch": "tsr watch",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"lint:ci": "biome ci .",
		"lint:fsd": "steiger ./src",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"test:run": "vitest run --passWithNoTests",
		"test:coverage": "vitest run --coverage",
		"theme:sync": "node scripts/sync-manifest-colors.mjs",
		"theme:check": "node scripts/check-design-tokens.mjs",
		"ci:preflight": "npm run theme:check && npm run lint:ci && npm run typecheck && npm run lint:fsd && npm run test:run",
		"ci:local": "npm run theme:check && npm run lint:ci && npm run typecheck && npm run lint:fsd && npm run test:coverage",
		"prepare": "node scripts/install-hooks.mjs"
	},
	"dependencies": {
		"@convex-dev/react-query": "latest",
		"@dagrejs/dagre": "^1.1.0",
		"@fontsource-variable/geist": "^5.2.8",
		"@react-three/drei": "^9.0.0",
		"@react-three/fiber": "^9.5.0",
		"@react-three/postprocessing": "^3.0.0",
		"@react-three/rapier": "^2.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"@tanstack/react-form": "^1.0.0",
		"@tanstack/react-query": "^5.0.0",
		"@tanstack/react-router": "~1.167.0",
		"@tanstack/react-start": "~1.166.0",
		"@tanstack/store": "^0.7.0",
		"@tanstack/zod-adapter": "^1.0.0",
		"@xstate/react": "^6.1.0",
		"@xyflow/react": "^12.10.0",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.0.0",
		"convex": "^1.25.0",
		"graphology": "^0.25.0",
		"howler": "^2.2.4",
		"lucide-react": "latest",
		"motion": "^12.36.0",
		"nitro": "npm:nitro-nightly@latest",
		"radix-ui": "^1.4.3",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"shadcn": "^4.1.0",
		"tailwind-merge": "^3.0.0",
		"tailwindcss": "^4.0.0",
		"three": "^0.172.0",
		"tone": "^14.8.0",
		"tw-animate-css": "^1.4.0",
		"uuid": "^11.0.0",
		"web-haptics": "^0.0.6",
		"xstate": "^5.19.0",
		"zod": "^3.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.0",
		"@feature-sliced/steiger-plugin": "latest",
		"@tanstack/router-cli": "~1.166.0",
		"@testing-library/jest-dom": "latest",
		"@testing-library/react": "latest",
		"@types/howler": "latest",
		"@types/node": "^22.10.2",
		"@types/react": "^19.1.0",
		"@types/react-dom": "^19.1.0",
		"@types/three": "latest",
		"@types/uuid": "latest",
		"@vitejs/plugin-react": "^5.1.4",
		"@vitest/coverage-v8": "^3.2.4",
		"happy-dom": "latest",
		"lefthook": "latest",
		"steiger": "latest",
		"typescript": "^5.7.0",
		"vite": "^7.3.1",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.0.0"
	}
}
